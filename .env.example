# Site URL
NEXT_PUBLIC_SITE_URL="https://muhamedbroja.com"

# Admin credentials (for seed)
ADMIN_EMAIL="admin@muhamedbroja.com"
ADMIN_PASSWORD="your-secure-password"

# Email notifications (Resend - https://resend.com)
RESEND_API_KEY=""
NOTIFY_EMAIL="admin@muhamedbroja.com"
FROM_EMAIL="Pyetje <noreply@muhamedbroja.com>"

# Google Search Console (optional)
GOOGLE_SITE_VERIFICATION=""
