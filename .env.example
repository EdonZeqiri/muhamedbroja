# Database (Neon PostgreSQL - https://neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/muhamedbroja?sslmode=require"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
